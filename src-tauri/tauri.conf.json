{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CEESVEE",
  "version": "0.2.1",
  "identifier": "com.ceesvee.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CEESVEE",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "app", "dmg", "deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "Fast CSV / delimited-file viewer and editor",
    "longDescription": "CEESVEE is a fast, open-source spreadsheet-style editor for CSV, TSV and other delimited files, built with Tauri and React.",
    "fileAssociations": [
      {
        "ext": ["csv"],
        "name": "CEESVEE.csv",
        "description": "CSV (CEESVEE)",
        "mimeType": "text/csv",
        "role": "Editor"
      },
      {
        "ext": ["tsv", "tab"],
        "name": "CEESVEE.tsv",
        "description": "TSV (CEESVEE)",
        "mimeType": "text/tab-separated-values",
        "role": "Editor"
      },
      {
        "ext": ["psv"],
        "name": "CEESVEE.psv",
        "description": "PSV (CEESVEE)",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxMDAzRjIxNEFFQTcyMTcKUldRWGN1cEtJVDhBWWRGdGNRa2FwcjVCRnY4Q0hSNEdlWWtGK3NnQS9kMzFZNWVFdk52Rng0Sm4K",
      "endpoints": ["https://github.com/soldforaloss/ceesvee/releases/latest/download/latest.json"]
    }
  }
}
