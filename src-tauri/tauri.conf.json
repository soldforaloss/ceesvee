{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CEESVEE",
  "version": "0.1.0",
  "identifier": "com.ceesvee.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CEESVEE",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg", "deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "Fast CSV / delimited-file viewer and editor",
    "longDescription": "CEESVEE is a fast, open-source spreadsheet-style editor for CSV, TSV and other delimited files, built with Tauri and React.",
    "fileAssociations": [
      {
        "ext": ["csv"],
        "name": "CSV File",
        "description": "Comma-separated values",
        "mimeType": "text/csv",
        "role": "Editor"
      },
      {
        "ext": ["tsv", "tab"],
        "name": "TSV File",
        "description": "Tab-separated values",
        "mimeType": "text/tab-separated-values",
        "role": "Editor"
      },
      {
        "ext": ["psv"],
        "name": "PSV File",
        "description": "Pipe-separated values",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
